# Customer Care contact form endpoint.
# When set, /about/customer-care POSTs JSON {firstName,lastName,email,orderNumber,message}.
# When unset, the form falls back to a prefilled mailto: draft to care@lineajewelry.com.
VITE_CONTACT_FORM_ENDPOINT=

# Checkout endpoint.
# When set, /checkout POSTs JSON {customer,shipping,billing?,shippingOption,items,subtotal,shippingCost,total}.
# When unset, the page opens a prefilled mailto: draft to orders@lineajewelry.com.
# Note: card details are never included in the mailto body.
VITE_CHECKOUT_ENDPOINT=
